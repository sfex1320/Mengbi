{
  "name": "mengbi",
  "version": "0.0.12",
  "description": "梦笔（mengbi）绘画工具箱 — 梦中之笔，绘未来之画",
  "main": "out/main/main.js",
  "author": "mengbi contributors",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=18.17"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "clean": "node -e \"const fs=require('fs');for(const d of ['out','app'])fs.rmSync(d,{recursive:true,force:true})\"",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,json,md,css}\"",
    "rebuild": "electron-rebuild",
    "postinstall": "electron-builder install-app-deps || true",
    "build:mall-thumbs": "node scripts/build-mall-thumbs.cjs",
    "package:win": "npm run build:mall-thumbs && npm run clean && electron-vite build && electron-builder --win",
    "package:mac": "npm run clean && electron-vite build && electron-builder --mac",
    "package:linux": "npm run clean && electron-vite build && electron-builder --linux"
  },
  "dependencies": {
    "@neplex/vectorizer": "^0.0.5",
    "better-sqlite3": "11.3.0",
    "duck-duck-scrape": "^2.2.7",
    "electron-log": "^5.2.0",
    "electron-updater": "^6.3.9",
    "expr-eval": "^2.0.2",
    "ffmpeg-static": "^5.3.0",
    "node-llama-cpp": "^3.18.1",
    "onnxruntime-node": "^1.26.0",
    "potrace": "^2.1.8",
    "sharp": "^0.33.5",
    "ws": "^8.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@imgly/background-removal": "^1.7.0",
    "@xyflow/react": "^12.10.2",
    "framer-motion": "^11.11.17",
    "konva": "^9.3.22",
    "onnxruntime-web": "^1.21.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-konva": "^18.2.14",
    "react-router-dom": "^6.28.0",
    "zustand": "^4.5.5",
    "@electron/rebuild": "^3.7.1",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.16.10",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.3.3",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^4.6.2",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vite-plugin-static-copy": "^2.3.2",
    "vitest": "^4.1.8"
  }
}
